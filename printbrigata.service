[Unit]
Description=Printbrigata Rechnungstool
After=network.target

[Service]
User=root
WorkingDirectory=/opt/rechnungs-tool
Environment="PATH=/opt/rechnungs-tool/.venv/bin:/usr/local/bin:/usr/bin:/bin"

ExecStart=/opt/rechnungs-tool/.venv/bin/python -m streamlit run Preislisten.py --server.port 8501 --server.address 127.0.0.1 --server.headless true

Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
